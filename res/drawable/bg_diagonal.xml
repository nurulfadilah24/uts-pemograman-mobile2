<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background utama -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1E7F7A"/>
        </shape>
    </item>

    <!-- Layer diagonal -->
    <item>
        <rotate
            android:fromDegrees="0"
            android:toDegrees="45"
            android:pivotX="100%"
            android:pivotY="0%">
            <shape android:shape="rectangle">
                <solid android:color="#0F5F5B"/>
                <size
                    android:width="500dp"
                    android:height="800dp"/>
            </shape>
        </rotate>
    </item>

</layer-list>
