<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Warna dasar (toska terang) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1E7F7A"/>
        </shape>
    </item>

    <!-- Bidang diagonal toska gelap -->
    <item>
        <rotate
            android:fromDegrees="-45"
            android:toDegrees="-45"
            android:pivotX="100%"
            android:pivotY="0%">
            <shape android:shape="rectangle">
                <solid android:color="#0F6E6B"/>
                <size
                    android:width="900dp"
                    android:height="1400dp"/>
            </shape>
        </rotate>
    </item>

</layer-list>
